name: mosaic
arch: amd64
platform: linux
version: ${VERSION}
section: net
priority: optional
maintainer: Dylan Hart <execxd@icloud.com>
description: A polished cross-platform BitTorrent client.
vendor: Dylan Hart
homepage: https://github.com/exec/mosaic
license: MIT
contents:
  - src: build/bin/mosaic
    dst: /usr/bin/mosaic
  - src: build/linux/mosaic.desktop
    dst: /usr/share/applications/mosaic.desktop
  - src: build/appicon.png
    dst: /usr/share/icons/hicolor/512x512/apps/mosaic.png
scripts:
  postinstall: scripts/linux-postinstall.sh
overrides:
  deb:
    # Built with -tags webkit2_41 — runtime dep is the 4.1 ABI which is
    # what Debian 12+ / Ubuntu 22.04+ ship. Older systems are unsupported;
    # they can use the .AppImage which bundles its own webkit.
    depends:
      - libgtk-3-0
      - libwebkit2gtk-4.1-0
  rpm:
    depends:
      - gtk3
      - webkit2gtk4.1
